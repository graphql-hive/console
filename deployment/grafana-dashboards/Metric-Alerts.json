        }
      ],
      "title": "Slow target groups",
      "type": "table"
    },
    {
      "datasource": { "type": "tempo", "uid": "TEMPO_DATASOURCE_UID" },
      "description": "Notification-dispatch tasks that exited with outcome=failed. Click a row for channel.type, rule.id, error attributes, and the outbound HTTP POST span.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
