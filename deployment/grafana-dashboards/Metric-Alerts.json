    {
      "datasource": { "type": "prometheus", "uid": "PROM_DATASOURCE_UID" },
      "description": "Fraction of evaluator ClickHouse queries that errored. Sustained above ~5% indicates ClickHouse degradation, network issues, or a malformed query for some rule.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "orange", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "9.3.6",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PROM_DATASOURCE_UID" },
          "editorMode": "code",
          "expr": "sum(rate(hive_metric_alert_clickhouse_query_duration_seconds_count{outcome=\"error\"}[$__rate_interval])) / clamp_min(sum(rate(hive_metric_alert_clickhouse_query_duration_seconds_count[$__rate_interval])), 0.001)",
          "legendFormat": "error ratio",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "ClickHouse error ratio",
      "type": "stat"
    },
