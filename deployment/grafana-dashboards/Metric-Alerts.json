      },
      "pluginVersion": "9.3.6",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PROM_DATASOURCE_UID" },
          "editorMode": "code",
          "expr": "sum by (outcome) (rate(hive_metric_alert_clickhouse_query_duration_seconds_count[$__rate_interval]))",
          "legendFormat": "{{outcome}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "ClickHouse query rate by outcome",
      "type": "timeseries"
